generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Hero {
  id        String   @id @default(cuid())
  name      String
  title     String
  subtitle  String
  tagline   String
  ctaText   String
  ctaLink   String
  resumeUrl String?
  updatedAt DateTime @updatedAt
}

model About {
  id        String   @id @default(cuid())
  bio       String   @db.Text
  bio2      String   @db.Text
  location  String
  email     String
  phone     String
  linkedin  String
  github    String
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  startDate   String
  endDate     String
  location    String
  description String[]
  order       Int      @default(0)
  current     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  longDesc    String?  @db.Text
  tech        String[]
  github      String?
  live        String?
  image       String?
  featured    Boolean  @default(false)
  category    String   @default("fullstack")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id       String  @id @default(cuid())
  name     String
  level    Int     @default(80)
  category String
  icon     String?
  order    Int     @default(0)
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  page      String
  ip        String?
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([page])
  @@index([ip])
}

model LinkClick {
  id        String   @id @default(cuid())
  label     String
  url       String?
  ip        String?
  country   String?
  city      String?
  device    String?
  browser   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([label])
}
